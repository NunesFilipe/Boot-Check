set -euo pipefail

# ── ANSI COLOR CODES ──────────────────────────────────────────────────────────
readonly RESET="\033[0m"
readonly BOLD="\033[1m"
readonly DIM="\033[2m"
readonly RED="\033[1;31m"
readonly GREEN="\033[1;32m"
readonly YELLOW="\033[1;33m"
readonly BLUE="\033[1;34m"
readonly CYAN="\033[1;36m"
readonly WHITE="\033[1;37m"

# ── CONFIGURATION (edit these if needed) ─────────────────────────────────────
# Path to OVMF firmware for UEFI mode.
# Arch:          /usr/share/edk2/x64/OVMF.4m.fd
# Debian/Ubuntu: /usr/share/OVMF/OVMF_CODE.fd
# Fedora:        /usr/share/edk2/ovmf/OVMF_CODE.fd
OVMF_PATH="/usr/share/edk2/x64/OVMF.4m.fd"

readonly QEMU_BIN="qemu-system-x86_64"
readonly RAM_MB=1024
readonly VERSION="1.1"
readonly ALLOWED_SYS_PREFIX="/sys/block/"

# ── TERMINAL HELPERS ──────────────────────────────────────────────────────────

clear_screen() {
    clear
    tput civis 2>/dev/null || true
}

restore_cursor() {
    tput cnorm 2>/dev/null || true
    echo -e "${RESET}"
}

trap restore_cursor EXIT

# ── TUI DRAWING ───────────────────────────────────────────────────────────────

draw_header() {
    echo
    echo -e "${CYAN}${BOLD}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║                                                          ║"
    echo "  ║             🖥   B O O T - C H E C K                    ║"
    echo "  ║            Testador de Pendrive Bootável                 ║"
    echo "  ║                    v${VERSION}                                 ║"
    echo "  ║                                                          ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"
}

draw_section() {
    local title="$1"
    echo -e "${YELLOW}${BOLD}"
    echo "  ┌──────────────────────────────────────────────────────────┐"
    printf  "  │  %-56s  │\n" "$title"
    echo "  └──────────────────────────────────────────────────────────┘"
    echo -e "${RESET}"
}

draw_footer() {
    echo -e "${DIM}"
    echo "  ──────────────────────────────────────────────────────────"
    echo "  Use as teclas indicadas para navegar  │  Ctrl+C para sair"
    echo "  ──────────────────────────────────────────────────────────"
    echo -e "${RESET}"
}

# ── LOG HELPERS ───────────────────────────────────────────────────────────────

msg_info()    { echo -e "  ${CYAN}[•]${RESET} $*"; }
msg_ok()      { echo -e "  ${GREEN}[✔]${RESET} $*"; }
msg_warn()    { echo -e "  ${YELLOW}[!]${RESET} $*"; }
msg_error()   { echo -e "  ${RED}[✘]${RESET} $*"; }

# ── USB DETECTION ─────────────────────────────────────────────────────────────

# Global session state — shared between menu functions
USB_DEVICES=()
USB_SIZES=()
USB_LABELS=()

# Parses lsblk output and populates USB_DEVICES / USB_SIZES / USB_LABELS
detect_usb_drives() {
    USB_DEVICES=()
    USB_SIZES=()
    USB_LABELS=()

    while IFS= read -r line; do
        local raw_name raw_size raw_tran

        # Extract fields using BASH_REMATCH to avoid subprocesses
        [[ "$line" =~ NAME=\"([^\"]+)\" ]]  && raw_name="${BASH_REMATCH[1]}"  || raw_name=""
        [[ "$line" =~ SIZE=\"([^\"]+)\" ]]  && raw_size="${BASH_REMATCH[1]}"  || raw_size=""
        [[ "$line" =~ TRAN=\"([^\"]+)\" ]]  && raw_tran="${BASH_REMATCH[1]}"  || raw_tran=""

        if [[ "$raw_tran" == "usb" ]] && \
           { [[ "$raw_name" =~ ^sd[a-z]$ ]] || [[ "$raw_name" =~ ^nvme[0-9]+n[0-9]+$ ]]; }; then
            USB_DEVICES+=("/dev/$raw_name")
            USB_SIZES+=("$raw_size")
            USB_LABELS+=("")
        fi
    done < <(lsblk -d -P -o NAME,SIZE,TRAN 2>/dev/null)
}

# Reads and sanitizes the human-readable model name from /sys/block/<dev>/device/model
sanitize_model_name() {
    local raw="$1"
    printf '%s' "$raw" | sed 's/[^a-zA-Z0-9 _.()+-]//g'
}

get_usb_model() {
    local dev="$1"
    local base
    base=$(basename "$dev")

    if [[ ! "$base" =~ ^[a-zA-Z0-9]+$ ]]; then
        echo "Dispositivo USB"
        return
    fi

    local model_file="${ALLOWED_SYS_PREFIX}${base}/device/model"
    if [[ -f "$model_file" ]]; then
        sanitize_model_name "$(< "$model_file")"
        echo
    else
        echo "Dispositivo USB"
    fi
}

# ── SESSION STATE ─────────────────────────────────────────────────────────────

# Globals used to pass selections between menu functions
SELECTED_DEV=""
BOOT_MODE=""

# ── MENUS ─────────────────────────────────────────────────────────────────────

menu_select_device() {
    while true; do
        clear_screen
        draw_header
        detect_usb_drives
        draw_section "Pendrives USB detectados"

        if [[ ${#USB_DEVICES[@]} -eq 0 ]]; then
            msg_warn "Nenhum pendrive USB encontrado."
            echo
            msg_info "Conecte um pendrive e pressione qualquer tecla para reescanear..."
            read -r -n1
            continue
        fi

        local i
        for i in "${!USB_DEVICES[@]}"; do
            local dev="${USB_DEVICES[$i]}"
            local size="${USB_SIZES[$i]}"
            local model
            model=$(get_usb_model "$dev")
            echo -e "  ${BOLD}${GREEN}[$(( i + 1 ))]${RESET}  ${WHITE}${dev}${RESET}  ${CYAN}${model}${RESET}  ${DIM}(${size})${RESET}"
        done

        echo
        echo -e "  ${BOLD}${YELLOW}[R]${RESET}  Reescanear dispositivos"
        echo -e "  ${BOLD}${RED}[Q]${RESET}  Sair"
        echo
        draw_footer

        tput cnorm 2>/dev/null || true
        echo -ne "  ${BOLD}Escolha o pendrive para testar: ${RESET}"
        local choice
        read -r choice
        tput civis 2>/dev/null || true

        choice="${choice^^}"

        case "$choice" in
            Q) exit 0 ;;
            R) continue ;;
            *)
                if [[ "$choice" =~ ^[0-9]+$ ]]; then
                    local idx=$(( choice - 1 ))
                    if [[ $idx -ge 0 && $idx -lt ${#USB_DEVICES[@]} ]]; then
                        SELECTED_DEV="${USB_DEVICES[$idx]}"
                        return 0
                    fi
                fi
                msg_warn "Opção inválida. Tente novamente."
                sleep 1
                ;;
        esac
    done
}

menu_select_mode() {
    local dev="$1"
    local model
    model=$(get_usb_model "$dev")

    while true; do
        clear_screen
        draw_header

        draw_section "Modo de Boot"

        echo -e "  ${DIM}Dispositivo selecionado:${RESET} ${WHITE}${BOLD}${dev}${RESET}  ${CYAN}${model}${RESET}"
        echo

        echo -e "  ${BOLD}${GREEN}[L]${RESET}  ${WHITE}BIOS Legado${RESET}"
        echo -e "       ${DIM}Modo clássico (MBR). Compatível com ISOs antigas,${RESET}"
        echo -e "       ${DIM}Linux/Windows gravados no modo legado.${RESET}"
        echo

        echo -e "  ${BOLD}${BLUE}[U]${RESET}  ${WHITE}UEFI${RESET}"
        echo -e "       ${DIM}Modo moderno (GPT/EFI). Compatível com ISOs recentes,${RESET}"
        echo -e "       ${DIM}Secure Boot desabilitado na simulação.${RESET}"
        echo

        echo -e "  ${BOLD}${YELLOW}[V]${RESET}  ${WHITE}Voltar${RESET}"
        echo -e "  ${BOLD}${RED}[Q]${RESET}  ${WHITE}Sair${RESET}"
        echo
        draw_footer

        tput cnorm 2>/dev/null || true
        echo -ne "  ${BOLD}Escolha o modo de boot: ${RESET}"
        local choice
        read -r choice
        tput civis 2>/dev/null || true

        choice="${choice^^}"

        case "$choice" in
            L) BOOT_MODE="bios"; return 0 ;;
            U) BOOT_MODE="uefi"; return 0 ;;
            V) return 1 ;;
            Q) exit 0 ;;
            *)
                msg_warn "Opção inválida. Digite L, U, V ou Q."
                sleep 1
                ;;
        esac
    done
}

# ── QEMU LAUNCH ───────────────────────────────────────────────────────────────

# Returns 1 if the parameters are invalid, 0 otherwise.
validate_launch_params() {
    local dev="$1"
    local mode="$2"

    if [[ ! "$dev" =~ ^/dev/[a-zA-Z0-9]+$ ]]; then
        msg_error "Dispositivo inválido: ${dev}"
        sleep 2
        return 1
    fi

    if [[ ! "$RAM_MB" =~ ^[0-9]+$ ]] || (( RAM_MB < 128 || RAM_MB > 65536 )); then
        msg_error "Valor de RAM inválido: ${RAM_MB}. Use um valor entre 128 e 65536."
        sleep 2
        return 1
    fi

    if [[ "$mode" == "uefi" ]]; then
        if [[ ! "$OVMF_PATH" =~ ^/ ]] || [[ ! -f "$OVMF_PATH" ]]; then
            msg_error "Firmware UEFI não encontrado ou path inválido: ${OVMF_PATH}"
            msg_info  "Instale o pacote 'edk2-ovmf' e configure OVMF_PATH no topo do script."
            echo
            read -rp "  Pressione Enter para voltar..."
            return 1
        fi
    fi
}

# Populates the global qemu_args array based on device and boot mode.
build_qemu_args() {
    local dev="$1"
    local mode="$2"

    qemu_args=(
        -name "bootcheck - ${dev}"
        -m "${RAM_MB}"
        -drive "file=${dev},format=raw,readonly=on,if=virtio,cache=none"
        -boot order=c,menu=on
        -display sdl
        -accel kvm
        -cpu host
        -machine type=pc
    )

    if [[ "$mode" == "uefi" ]]; then
        qemu_args+=( -bios "${OVMF_PATH}" )
        qemu_args=("${qemu_args[@]/type=pc/type=q35}")
    fi
}

launch_qemu() {
    local dev="$1"
    local mode="$2"

    validate_launch_params "$dev" "$mode" || return 1

    local model
    model=$(get_usb_model "$dev")

    clear_screen
    draw_header
    draw_section "Iniciando simulação de boot"

    echo -e "  ${DIM}Dispositivo :${RESET} ${WHITE}${BOLD}${dev}${RESET}  ${CYAN}${model}${RESET}"
    if [[ "$mode" == "uefi" ]]; then
        echo -e "  ${DIM}Modo        :${RESET} ${BLUE}${BOLD}UEFI${RESET} ${DIM}(OVMF)${RESET}"
    else
        echo -e "  ${DIM}Modo        :${RESET} ${GREEN}${BOLD}BIOS Legado${RESET} ${DIM}(MBR)${RESET}"
    fi
    echo -e "  ${DIM}RAM         :${RESET} ${WHITE}${RAM_MB} MB${RESET}"
    echo

    local use_sudo=0
    if [[ ! -r "$dev" ]]; then
        msg_warn "Permissão negada para ${dev}. Será solicitado sudo."
        use_sudo=1
    fi

    msg_info "Aguarde, iniciando QEMU..."
    echo
    msg_warn "Feche a janela do QEMU ou pressione Ctrl+Alt+Q para encerrar."
    echo
    tput cnorm 2>/dev/null || true

    local qemu_args=()
    build_qemu_args "$dev" "$mode"

    local exit_code=0
    if (( use_sudo == 1 )); then
        sudo "$QEMU_BIN" "${qemu_args[@]}" || exit_code=$?
    else
        "$QEMU_BIN" "${qemu_args[@]}" || exit_code=$?
    fi

    echo
    if [[ $exit_code -eq 0 ]]; then
        msg_ok "Simulação encerrada com sucesso."
    else
        msg_error "O QEMU encerrou com erro (código: ${exit_code}) ou foi fechado forçadamente."
    fi

    echo
    echo -e "  ${DIM}Pressione Enter para voltar ao menu...${RESET}"
    tput cnorm 2>/dev/null || true
    read -r
}

# ── STARTUP ───────────────────────────────────────────────────────────────────

check_deps() {
    local missing=()

    command -v "$QEMU_BIN" &>/dev/null || missing+=("$QEMU_BIN")
    command -v lsblk       &>/dev/null || missing+=("lsblk (util-linux)")

    if [[ ${#missing[@]} -eq 0 ]]; then
        return 0
    fi

    echo
    msg_error "Dependências faltando:"
    for dep in "${missing[@]}"; do
        echo -e "    ${RED}✘${RESET}  $dep"
    done
    echo
    msg_info "Arch Linux  : sudo pacman -S qemu-full edk2-ovmf util-linux"
    msg_info "Debian/Ubuntu: sudo apt install qemu-system-x86 ovmf"
    msg_info "Fedora      : sudo dnf install qemu-system-x86 edk2-ovmf"
    echo
    exit 1
}

main() {
    check_deps

    while true; do
        menu_select_device

        if ! menu_select_mode "$SELECTED_DEV"; then
            continue
        fi

        launch_qemu "$SELECTED_DEV" "$BOOT_MODE"
    done
}

main "$@"
